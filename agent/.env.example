# Trove Subscriber Agent — environment
# Copy to .env for local dev. All values below are the built-in defaults.

# Base URL of the Trove Rails archive's internal API.
TROVE_ARCHIVE_URL=http://localhost:3033

# Bearer token for the internal API (must match Rails config.x.trove.internal_api_token).
TROVE_INTERNAL_API_TOKEN=dev-only-internal-token

# Path to the durable SQLite target store.
TROVE_AGENT_DB=./data/targets.db

# Stable worker id used when leasing targets / claiming confirmations.
TROVE_WORKER_ID=agent-1

# ── A3 fleet + footprint ──────────────────────────────────────────────────────
# Comma-separated egress proxy URLs for rotation (e.g. http://h:port,socks5://h:port).
# Unset/empty = direct connection (the dev/test default). The rotation seam +
# dead-proxy detection are built; the real provider is deferred (plug URLs here).
# TROVE_PROXY_URLS=

# Throttle (anti-block pacing — "weeks not hours"). Defaults shown.
TROVE_RATE_MAX=30                  # global cap: max attempt-starts per window
TROVE_RATE_WINDOW_MS=60000         # sliding-window length (ms) for the rate cap
TROVE_DOMAIN_MIN_DELAY_MS=21600000 # min gap (ms) between two hits on one domain (6h)
TROVE_JITTER_MS=750                # max jitter padded onto each pacing wait

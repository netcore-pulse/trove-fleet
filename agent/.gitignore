# Subscriber Agent (Node/TS) — local artifacts.
# NOTE: the repo-root .gitignore already covers node_modules/, dist/, *.log;
# this file is a belt-and-suspenders for anyone running from inside agent/.
node_modules/
dist/
*.log

# Local durable store (SQLite target store + WAL sidecars)
data/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Local env
.env
.env.*
!.env.example
